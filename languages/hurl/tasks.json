[
  {
    "label": "Run hurl request",
    "command": "hurl-runner",
    "args": ["$ZED_FILE", "$ZED_ROW"],
    "tags": ["hurl-request"]
  },
  {
    "label": "Run all hurl requests",
    "command": "hurl",
    "args": ["$ZED_FILE"],
    "tags": ["hurl-request"]
  },
  {
    "label": "Run selected hurl requests",
    "command": "hurl-runner",
    "args": ["--selected", "$ZED_FILE"],
    "env": {
      "HURL_SELECTED": "$ZED_SELECTED_TEXT"
    },
    "tags": ["hurl-request"]
  }
]
